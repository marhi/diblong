generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  sl
  en
  hr
}

enum RoleName {
  CUSTOMER
  STAFF
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}

enum PageKey {
  HOME
  ABOUT
  FAQ
  SHIPPING
  PRIVACY
  TERMS
  CONTACT
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  roles        UserRole[]
  addresses    Address[]
  orders       Order[]
  carts        Cart[]
  refreshTokens RefreshToken[]
  wishlist     WishlistItem[]
}

model Role {
  id    String     @id @default(uuid())
  name  RoleName   @unique
  users UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  label       String?
  line1       String
  line2       String?
  city        String
  postalCode  String
  countryCode String
  isDefault   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MediaAsset {
  id          String   @id @default(uuid())
  sourceUrl   String?
  storedPath  String?
  mimeType    String?
  fileName    String?
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())
  productImages ProductImage[]
  banners       PromoBanner[]
}

model Category {
  id           String                @id @default(uuid())
  sortOrder    Int                   @default(0)
  isActive     Boolean               @default(true)
  translations CategoryTranslation[]
  products     Product[]
}

model CategoryTranslation {
  id             String   @id @default(uuid())
  categoryId     String
  locale         Locale
  title          String
  slug           String
  introHtml      String?  @db.Text
  faqJson        String?  @db.Text
  metaTitle      String?
  metaDescription String? @db.Text
  ogTitle        String?
  ogDescription  String?  @db.Text
  ogImageUrl     String?
  canonicalPath  String?
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@unique([locale, slug])
}

model Product {
  id            String               @id @default(uuid())
  sku           String               @unique
  price         Decimal              @db.Decimal(12, 2)
  compareAtPrice Decimal?            @db.Decimal(12, 2)
  stock         Int                  @default(0)
  isActive      Boolean              @default(true)
  isFeatured    Boolean              @default(false)
  isBestseller  Boolean              @default(false)
  popularity    Int                  @default(0)
  categoryId    String?
  category      Category?            @relation(fields: [categoryId], references: [id])
  translations  ProductTranslation[]
  images        ProductImage[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  relatedFrom   ProductRelation[]    @relation("ProductRelatedFrom")
  relatedTo     ProductRelation[]    @relation("ProductRelatedTo")
  wishlist      WishlistItem[]

  @@index([categoryId])
}

model ProductTranslation {
  id               String   @id @default(uuid())
  productId        String
  locale           Locale
  title            String
  slug             String
  shortDescription String?  @db.Text
  longDescription  String?  @db.Text
  usageNotes       String?  @db.Text
  faqJson          String?  @db.Text
  disclaimer       String?  @db.Text
  metaTitle        String?
  metaDescription  String?  @db.Text
  ogTitle          String?
  ogDescription    String?  @db.Text
  ogImageUrl       String?
  canonicalPath    String?
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@unique([locale, slug])
}

model ProductImage {
  id           String     @id @default(uuid())
  productId  String
  mediaAssetId String
  sortOrder    Int        @default(0)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  media        MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductRelation {
  fromProductId String
  toProductId   String
  fromProduct   Product @relation("ProductRelatedFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProduct     Product @relation("ProductRelatedTo", fields: [toProductId], references: [id], onDelete: Cascade)

  @@id([fromProductId, toProductId])
}

model Cart {
  id         String     @id @default(uuid())
  guestToken String?    @unique
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CartItem[]
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  cartId    String
  productId String
  qty       Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([cartId, productId])
}

model Order {
  id               String      @id @default(uuid())
  userId           String?
  guestEmail       String?
  status           OrderStatus @default(PENDING)
  currency         String      @default("EUR")
  subtotal         Decimal     @db.Decimal(12, 2)
  shippingTotal    Decimal     @db.Decimal(12, 2)
  total            Decimal     @db.Decimal(12, 2)
  shippingAddress  Json?
  billingAddress   Json?
  countryCode      String
  paymentProvider  String?
  paymentReference String?
  adminNotes       String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User?       @relation(fields: [userId], references: [id])
  items            OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id             String  @id @default(uuid())
  orderId        String
  productId      String
  titleSnapshot  String
  unitPrice      Decimal @db.Decimal(12, 2)
  qty            Int
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model ShippingZone {
  id        String             @id @default(uuid())
  name      String
  sortOrder Int                @default(0)
  countries ShippingCountry[]
  rates     ShippingRate[]
}

model ShippingCountry {
  id          String       @id @default(uuid())
  zoneId      String
  code        String       @unique
  notesSl     String?      @db.Text
  notesEn     String?      @db.Text
  notesHr     String?      @db.Text
  zone        ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

model ShippingRate {
  id                     String       @id @default(uuid())
  zoneId                 String
  flatRate               Decimal      @db.Decimal(12, 2)
  freeShippingThreshold  Decimal?     @db.Decimal(12, 2)
  zone                   ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

model Page {
  id           String            @id @default(uuid())
  key          PageKey           @unique
  translations PageTranslation[]
}

model PageTranslation {
  id              String   @id @default(uuid())
  pageId          String
  locale          Locale
  title           String
  slug            String
  bodyHtml        String?  @db.Text
  metaTitle       String?
  metaDescription String?  @db.Text
  ogTitle         String?
  ogDescription   String?  @db.Text
  ogImageUrl      String?
  canonicalPath   String?
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@unique([locale, slug])
}

model SeoEntry {
  id              String  @id @default(uuid())
  routeKey        String
  locale          Locale
  metaTitle       String?
  metaDescription String? @db.Text
  ogTitle         String?
  ogDescription   String? @db.Text
  ogImageUrl      String?
  canonicalPath   String?
  noindex         Boolean @default(false)

  @@unique([routeKey, locale])
}

model PromoBanner {
  id           String     @id @default(uuid())
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  imageMediaId String?
  linkUrl      String?
  image        MediaAsset? @relation(fields: [imageMediaId], references: [id])
  translations PromoBannerTranslation[]
}

model PromoBannerTranslation {
  id        String      @id @default(uuid())
  bannerId  String
  locale    Locale
  headline  String
  subline   String?
  ctaLabel  String?
  ctaPath   String?
  banner    PromoBanner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@unique([bannerId, locale])
}

model SiteSetting {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}

model WishlistItem {
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}
